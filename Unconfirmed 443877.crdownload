<div class="jp-CodeMirrorEditor jp-Editor jp-InputArea-editor" data-type="inline">
<div class="cm-editor cm-s-jupyter">
<div class="highlight hl-ipython3"><pre><span></span><span class="n">new_outliers</span> <span class="o">=</span> <span class="n">city_df</span><span class="p">[</span><span class="n">city_df</span><span class="p">[</span><span class="s2">"AQI"</span><span class="p">]</span> <span class="o">&gt;</span> <span class="n">upper_limit</span><span class="p">]</span>

<span class="nb">print</span><span class="p">(</span><span class="s2">"Remaining Extreme Values:"</span><span class="p">)</span>
<span class="nb">print</span><span class="p">(</span><span class="nb">len</span><span class="p">(</span><span class="n">new_outliers</span><span class="p">))</span>
