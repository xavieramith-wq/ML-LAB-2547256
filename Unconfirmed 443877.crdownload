</div><div class="jp-Cell jp-CodeCell jp-Notebook-cell" id="cell-id=07a7adf6-7ca6-4aca-8e25-9e1b7a555580">
<div class="jp-Cell-inputWrapper" tabindex="0">
<div class="jp-Collapser jp-InputCollapser jp-Cell-inputCollapser">
</div>
<div class="jp-InputArea jp-Cell-inputArea">
<div class="jp-InputPrompt jp-InputArea-prompt">In [150]:</div>
<div class="jp-CodeMirrorEditor jp-Editor jp-InputArea-editor" data-type="inline">
<div class="cm-editor cm-s-jupyter">
<div class="highlight hl-ipython3"><pre><span></span><span class="kn">import</span> <span class="nn">pandas</span> <span class="k">as</span> <span class="nn">pd</span>
<span class="kn">import</span> <span class="nn">matplotlib.pyplot</span> <span class="k">as</span> <span class="nn">plt</span>

<span class="c1"># Load datasets</span>
<span class="n">aqi</span> <span class="o">=</span> <span class="n">pd</span><span class="o">.</span><span class="n">read_csv</span><span class="p">(</span><span class="s2">"city_day.csv"</span><span class="p">)</span>
<span class="n">crop</span> <span class="o">=</span> <span class="n">pd</span><span class="o">.</span><span class="n">read_csv</span><span class="p">(</span><span class="s2">"crop_production.csv"</span><span class="p">)</span>

<span class="c1"># Remove missing AQI values</span>
<span class="n">aqi</span> <span class="o">=</span> <span class="n">aqi</span><span class="o">.</span><span class="n">dropna</span><span class="p">(</span><span class="n">subset</span><span class="o">=</span><span class="p">[</span><span class="s2">"AQI"</span><span class="p">])</span>

<span class="c1"># Create State column from City</span>
<span class="n">aqi</span><span class="p">[</span><span class="s2">"State"</span><span class="p">]</span> <span class="o">=</span> <span class="n">aqi</span><span class="p">[</span><span class="s2">"City"</span><span class="p">]</span>

<span class="c1"># Convert cities into states</span>
<span class="n">aqi</span><span class="p">[</span><span class="s2">"State"</span><span class="p">]</span> <span class="o">=</span> <span class="n">aqi</span><span class="p">[</span><span class="s2">"State"</span><span class="p">]</span><span class="o">.</span><span class="n">replace</span><span class="p">({</span>
    <span class="s2">"Ahmedabad"</span><span class="p">:</span> <span class="s2">"Gujarat"</span><span class="p">,</span>
    <span class="s2">"Delhi"</span><span class="p">:</span> <span class="s2">"Delhi"</span><span class="p">,</span>
    <span class="s2">"Mumbai"</span><span class="p">:</span> <span class="s2">"Maharashtra"</span><span class="p">,</span>
    <span class="s2">"Chennai"</span><span class="p">:</span> <span class="s2">"Tamil Nadu"</span><span class="p">,</span>
    <span class="s2">"Kolkata"</span><span class="p">:</span> <span class="s2">"West Bengal"</span><span class="p">,</span>
    <span class="s2">"Bengaluru"</span><span class="p">:</span> <span class="s2">"Karnataka"</span><span class="p">,</span>
    <span class="s2">"Hyderabad"</span><span class="p">:</span> <span class="s2">"Telangana"</span><span class="p">,</span>
    <span class="s2">"Lucknow"</span><span class="p">:</span> <span class="s2">"Uttar Pradesh"</span><span class="p">,</span>
    <span class="s2">"Patna"</span><span class="p">:</span> <span class="s2">"Bihar"</span><span class="p">,</span>
    <span class="s2">"Jaipur"</span><span class="p">:</span> <span class="s2">"Rajasthan"</span><span class="p">,</span>
    <span class="s2">"Bhopal"</span><span class="p">:</span> <span class="s2">"Madhya Pradesh"</span><span class="p">,</span>
    <span class="s2">"Amaravati"</span><span class="p">:</span> <span class="s2">"Andhra Pradesh"</span><span class="p">,</span>
    <span class="s2">"Chandigarh"</span><span class="p">:</span> <span class="s2">"Chandigarh"</span><span class="p">,</span>
    <span class="s2">"Coimbatore"</span><span class="p">:</span> <span class="s2">"Tamil Nadu"</span><span class="p">,</span>
    <span class="s2">"Ernakulam"</span><span class="p">:</span> <span class="s2">"Kerala"</span><span class="p">,</span>
    <span class="s2">"Guwahati"</span><span class="p">:</span> <span class="s2">"Assam"</span><span class="p">,</span>
    <span class="s2">"Kochi"</span><span class="p">:</span> <span class="s2">"Kerala"</span><span class="p">,</span>
    <span class="s2">"Shillong"</span><span class="p">:</span> <span class="s2">"Meghalaya"</span><span class="p">,</span>
    <span class="s2">"Talcher"</span><span class="p">:</span> <span class="s2">"Odisha"</span><span class="p">,</span>
    <span class="s2">"Thiruvananthapuram"</span><span class="p">:</span> <span class="s2">"Kerala"</span><span class="p">,</span>
    <span class="s2">"Visakhapatnam"</span><span class="p">:</span> <span class="s2">"Andhra Pradesh"</span>
<span class="p">})</span>

<span class="c1"># Average AQI by state</span>
<span class="n">state_aqi</span> <span class="o">=</span> <span class="n">aqi</span><span class="o">.</span><span class="n">groupby</span><span class="p">(</span><span class="s2">"State"</span><span class="p">)[</span><span class="s2">"AQI"</span><span class="p">]</span><span class="o">.</span><span class="n">mean</span><span class="p">()</span><span class="o">.</span><span class="n">reset_index</span><span class="p">()</span>

<span class="n">state_aqi</span><span class="o">.</span><span class="n">columns</span> <span class="o">=</span> <span class="p">[</span><span class="s2">"State"</span><span class="p">,</span> <span class="s2">"Avg_AQI"</span><span class="p">]</span>

<span class="c1"># Crop dataset</span>
<span class="n">crop</span> <span class="o">=</span> <span class="n">crop</span><span class="o">.</span><span class="n">rename</span><span class="p">(</span><span class="n">columns</span><span class="o">=</span><span class="p">{</span><span class="s2">"State_Name"</span><span class="p">:</span> <span class="s2">"State"</span><span class="p">})</span>

<span class="c1"># Total production by state</span>
<span class="n">state_crop</span> <span class="o">=</span> <span class="n">crop</span><span class="o">.</span><span class="n">groupby</span><span class="p">(</span><span class="s2">"State"</span><span class="p">)[</span><span class="s2">"Production"</span><span class="p">]</span><span class="o">.</span><span class="n">sum</span><span class="p">()</span><span class="o">.</span><span class="n">reset_index</span><span class="p">()</span>

<span class="n">state_crop</span><span class="o">.</span><span class="n">columns</span> <span class="o">=</span> <span class="p">[</span><span class="s2">"State"</span><span class="p">,</span> <span class="s2">"Total_Production"</span><span class="p">]</span>

<span class="c1"># Merge datasets</span>
<span class="n">merged</span> <span class="o">=</span> <span class="n">pd</span><span class="o">.</span><span class="n">merge</span><span class="p">(</span>
    <span class="n">state_aqi</span><span class="p">,</span>
    <span class="n">state_crop</span><span class="p">,</span>
    <span class="n">on</span><span class="o">=</span><span class="s2">"State"</span>
<span class="p">)</span>

<span class="c1"># Top 5 most polluted states</span>
<span class="n">dirty_states</span> <span class="o">=</span> <span class="n">merged</span><span class="o">.</span><span class="n">sort_values</span><span class="p">(</span>
    <span class="n">by</span><span class="o">=</span><span class="s2">"Avg_AQI"</span><span class="p">,</span>
    <span class="n">ascending</span><span class="o">=</span><span class="kc">False</span>
<span class="p">)</span><span class="o">.</span><span class="n">head</span><span class="p">(</span><span class="mi">5</span><span class="p">)</span>

<span class="c1"># Top 5 least polluted states</span>
<span class="n">clean_states</span> <span class="o">=</span> <span class="n">merged</span><span class="o">.</span><span class="n">sort_values</span><span class="p">(</span>
    <span class="n">by</span><span class="o">=</span><span class="s2">"Avg_AQI"</span>
<span class="p">)</span><span class="o">.</span><span class="n">head</span><span class="p">(</span><span class="mi">5</span><span class="p">)</span>

<span class="c1"># -----------------------------</span>
<span class="c1"># Chart 1</span>
<span class="c1"># Most Polluted States</span>
<span class="c1"># -----------------------------</span>

<span class="n">plt</span><span class="o">.</span><span class="n">figure</span><span class="p">(</span><span class="n">figsize</span><span class="o">=</span><span class="p">(</span><span class="mi">8</span><span class="p">,</span><span class="mi">5</span><span class="p">))</span>

<span class="n">plt</span><span class="o">.</span><span class="n">barh</span><span class="p">(</span>
    <span class="n">dirty_states</span><span class="p">[</span><span class="s2">"State"</span><span class="p">],</span>
    <span class="n">dirty_states</span><span class="p">[</span><span class="s2">"Avg_AQI"</span><span class="p">],</span>
    <span class="n">color</span><span class="o">=</span><span class="s2">"red"</span>
<span class="p">)</span>

<span class="n">plt</span><span class="o">.</span><span class="n">title</span><span class="p">(</span><span class="s2">"Top 5 Most Polluted States"</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">xlabel</span><span class="p">(</span><span class="s2">"Average AQI"</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">ylabel</span><span class="p">(</span><span class="s2">"State"</span><span class="p">)</span>

<span class="n">plt</span><span class="o">.</span><span class="n">show</span><span class="p">()</span>

<span class="c1"># -----------------------------</span>
<span class="c1"># Chart 2</span>
<span class="c1"># Least Polluted States</span>
<span class="c1"># -----------------------------</span>

<span class="n">plt</span><span class="o">.</span><span class="n">figure</span><span class="p">(</span><span class="n">figsize</span><span class="o">=</span><span class="p">(</span><span class="mi">8</span><span class="p">,</span><span class="mi">5</span><span class="p">))</span>

<span class="n">plt</span><span class="o">.</span><span class="n">barh</span><span class="p">(</span>
    <span class="n">clean_states</span><span class="p">[</span><span class="s2">"State"</span><span class="p">],</span>
    <span class="n">clean_states</span><span class="p">[</span><span class="s2">"Avg_AQI"</span><span class="p">],</span>
    <span class="n">color</span><span class="o">=</span><span class="s2">"green"</span>
<span class="p">)</span>

<span class="n">plt</span><span class="o">.</span><span class="n">title</span><span class="p">(</span><span class="s2">"Top 5 Least Polluted States"</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">xlabel</span><span class="p">(</span><span class="s2">"Average AQI"</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">ylabel</span><span class="p">(</span><span class="s2">"State"</span><span class="p">)</span>

<span class="n">plt</span><span class="o">.</span><span class="n">show</span><span class="p">()</span>

<span class="c1"># -----------------------------</span>
<span class="c1"># Chart 3</span>
<span class="c1"># Crop Production of Most Polluted States</span>
<span class="c1"># -----------------------------</span>

<span class="n">plt</span><span class="o">.</span><span class="n">figure</span><span class="p">(</span><span class="n">figsize</span><span class="o">=</span><span class="p">(</span><span class="mi">8</span><span class="p">,</span><span class="mi">5</span><span class="p">))</span>

<span class="n">plt</span><span class="o">.</span><span class="n">barh</span><span class="p">(</span>
    <span class="n">dirty_states</span><span class="p">[</span><span class="s2">"State"</span><span class="p">],</span>
    <span class="n">dirty_states</span><span class="p">[</span><span class="s2">"Total_Production"</span><span class="p">]</span>
<span class="p">)</span>

<span class="n">plt</span><span class="o">.</span><span class="n">title</span><span class="p">(</span><span class="s2">"Crop Production in Most Polluted States"</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">xlabel</span><span class="p">(</span><span class="s2">"Production"</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">ylabel</span><span class="p">(</span><span class="s2">"State"</span><span class="p">)</span>

<span class="n">plt</span><span class="o">.</span><span class="n">show</span><span class="p">()</span>

<span class="c1"># -----------------------------</span>
<span class="c1"># Chart 4</span>
<span class="c1"># Crop Production of Least Polluted States</span>
<span class="c1"># -----------------------------</span>

<span class="n">plt</span><span class="o">.</span><span class="n">figure</span><span class="p">(</span><span class="n">figsize</span><span class="o">=</span><span class="p">(</span><span class="mi">8</span><span class="p">,</span><span class="mi">5</span><span class="p">))</span>

<span class="n">plt</span><span class="o">.</span><span class="n">barh</span><span class="p">(</span>
    <span class="n">clean_states</span><span class="p">[</span><span class="s2">"State"</span><span class="p">],</span>
    <span class="n">clean_states</span><span class="p">[</span><span class="s2">"Total_Production"</span><span class="p">]</span>
<span class="p">)</span>

<span class="n">plt</span><span class="o">.</span><span class="n">title</span><span class="p">(</span><span class="s2">"Crop Production in Least Polluted States"</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">xlabel</span><span class="p">(</span><span class="s2">"Production"</span><span class="p">)</span>
<span class="n">plt</span><span class="o">.</span><span class="n">ylabel</span><span class="p">(</span><span class="s2">"State"</span><span class="p">)</span>

<span class="n">plt</span><span class="o">.</span><span class="n">show</span><span class="p">()</span>

<span class="c1"># Display data</span>

<span class="nb">print</span><span class="p">(</span><span class="s2">"</span><span class="se">\n</span><span class="s2">Most Polluted States"</span><span class="p">)</span>
<span class="nb">print</span><span class="p">(</span><span class="n">dirty_states</span><span class="p">)</span>

<span class="nb">print</span><span class="p">(</span><span class="s2">"</span><span class="se">\n</span><span class="s2">Least Polluted States"</span><span class="p">)</span>
<span class="nb">print</span><span class="p">(</span><span class="n">clean_states</span><span class="p">)</span>
</pre></div>
</div>
</div>
</div>
</div>
