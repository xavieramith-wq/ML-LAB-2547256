</div><div class="jp-Cell jp-CodeCell jp-Notebook-cell" id="cell-id=0cc8c176-90ef-42a2-86c1-e095ed744510">
<div class="jp-Cell-inputWrapper" tabindex="0">
<div class="jp-Collapser jp-InputCollapser jp-Cell-inputCollapser">
</div>
<div class="jp-InputArea jp-Cell-inputArea">
<div class="jp-InputPrompt jp-InputArea-prompt">In [101]:</div>
<div class="jp-CodeMirrorEditor jp-Editor jp-InputArea-editor" data-type="inline">
<div class="cm-editor cm-s-jupyter">
<div class="highlight hl-ipython3"><pre><span></span><span class="c1"># prepare crop — average production per state</span>
<span class="n">crop</span> <span class="o">=</span> <span class="n">crop</span><span class="o">.</span><span class="n">rename</span><span class="p">(</span><span class="n">columns</span><span class="o">=</span><span class="p">{</span><span class="s2">"State_Name"</span><span class="p">:</span> <span class="s2">"State"</span><span class="p">})</span>
<span class="n">state_crop</span> <span class="o">=</span> <span class="n">crop</span><span class="o">.</span><span class="n">groupby</span><span class="p">(</span><span class="s2">"State"</span><span class="p">)[</span><span class="s2">"Production"</span><span class="p">]</span><span class="o">.</span><span class="n">sum</span><span class="p">()</span><span class="o">.</span><span class="n">reset_index</span><span class="p">()</span>
<span class="n">state_crop</span><span class="o">.</span><span class="n">columns</span> <span class="o">=</span> <span class="p">[</span><span class="s2">"State"</span><span class="p">,</span> <span class="s2">"Total_Production"</span><span class="p">]</span>

<span class="c1"># join AQI extremes with crop production</span>
<span class="n">dirty_with_crop</span> <span class="o">=</span> <span class="n">pd</span><span class="o">.</span><span class="n">merge</span><span class="p">(</span><span class="n">top5_dirty</span><span class="p">,</span> <span class="n">state_crop</span><span class="p">,</span> <span class="n">on</span><span class="o">=</span><span class="s2">"State"</span><span class="p">,</span> <span class="n">how</span><span class="o">=</span><span class="s2">"left"</span><span class="p">)</span>
<span class="n">clean_with_crop</span> <span class="o">=</span> <span class="n">pd</span><span class="o">.</span><span class="n">merge</span><span class="p">(</span><span class="n">top5_clean</span><span class="p">,</span> <span class="n">state_crop</span><span class="p">,</span> <span class="n">on</span><span class="o">=</span><span class="s2">"State"</span><span class="p">,</span> <span class="n">how</span><span class="o">=</span><span class="s2">"left"</span><span class="p">)</span>

<span class="nb">print</span><span class="p">(</span><span class="s2">"Most polluted + their production:"</span><span class="p">)</span>
<span class="nb">print</span><span class="p">(</span><span class="n">dirty_with_crop</span><span class="o">.</span><span class="n">to_string</span><span class="p">(</span><span class="n">index</span><span class="o">=</span><span class="kc">False</span><span class="p">))</span>
<span class="nb">print</span><span class="p">(</span><span class="s2">"</span><span class="se">\n</span><span class="s2">Least polluted + their production:"</span><span class="p">)</span>
<span class="nb">print</span><span class="p">(</span><span class="n">clean_with_crop</span><span class="o">.</span><span class="n">to_string</span><span class="p">(</span><span class="n">index</span><span class="o">=</span><span class="kc">False</span><span class="p">))</span>
</pre></div>
</div>
</div>
</div>
</div>
<div class="jp-Cell-outputWrapper">
<div class="jp-Collapser jp-OutputCollapser jp-Cell-outputCollapser">
